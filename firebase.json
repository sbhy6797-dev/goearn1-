{
  "functions": [
    {
      "codebase": "functions_main",
      "source": "functions_main"
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/postback",
        "function": {
          "functionId": "offerwallXPostback",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}