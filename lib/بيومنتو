// FULL DASHBOARD CODE (FIXED TIMER + FULL UI)
import 'dart:async';
import 'package:flutter/material.dart';
import 'package:pedometer/pedometer.dart';
import 'package:permission_handler/permission_handler.dart';
import 'package:google_mobile_ads/google_mobile_ads.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:firebase_auth/firebase_auth.dart';

import 'payment_screen.dart';
import 'settings_screen.dart';
import 'lucky_spin_screen.dart';
import 'main.dart';

class DashboardScreen extends StatefulWidget {
  final int totalCoins;
  const DashboardScreen({super.key, required this.totalCoins});

  @override
  State<DashboardScreen> createState() => _DashboardScreenState();
}

class _DashboardScreenState extends State<DashboardScreen> with RouteAware {
  int steps = 0;
  int coins = 0;
  int totalCoins = 0;

  List<int> speedLevels = [3, 5, 7];

  int initialSteps = 0;
  bool isFirstUpdate = true;

  late StreamSubscription<StepCount> _stepSubscription;
  late Stream<StepCount> _stepCountStream;

  final int maxSteps = 70000;
  final int stepPerCoin = 100;

  late final DocumentReference userDoc;
  late final String uid;
  Timer? _debounce;

  double boostMultiplier = 1.0;
  Timer? countdownTimer;
  DateTime? boostEndTime;
  int remainingSeconds = 0;

  int adsWatchedCount = 0;

  InterstitialAd? _interstitialAd;
  bool _isInterstitialReady = false;

  @override
  void initState() {
    super.initState();

    totalCoins = widget.totalCoins;

    final user = FirebaseAuth.instance.currentUser!;
    uid = user.uid;
    userDoc = FirebaseFirestore.instance.collection('users').doc(uid);

    initApp();

    Future.delayed(const Duration(milliseconds: 500), () {
      _restoreTimerFromFirebase();
    });

    _loadInterstitial();
  }

  Future<void> initApp() async {
    var status = await Permission.activityRecognition.request();
    if (!status.isGranted) return;

    await loadData();
    initPedometer();
  }

  void initPedometer() {
    _stepCountStream = Pedometer.stepCountStream;
    _stepSubscription = _stepCountStream.listen(onStepCount);
  }

  void onStepCount(StepCount event) {
    if (isFirstUpdate) {
      initialSteps = event.steps;
      isFirstUpdate = false;
    }

    setState(() {
      steps = (event.steps - initialSteps).clamp(0, maxSteps);
      coins = ((steps * boostMultiplier) ~/ stepPerCoin);
    });

    _debounce?.cancel();
    _debounce = Timer(const Duration(seconds: 20), _updateFirebase);
  }

  // ================= BOOST =================

  void addBoostTime(int secondsToAdd, int speed) async {
    if (boostEndTime != null && boostEndTime!.isAfter(DateTime.now())) {
      boostEndTime = boostEndTime!.add(Duration(seconds: secondsToAdd));
    } else {
      boostEndTime = DateTime.now().add(Duration(seconds: secondsToAdd));
    }

    boostMultiplier = speed.toDouble();

    await userDoc.set({
      'boostEndTime': Timestamp.fromDate(boostEndTime!),
      'boostMultiplier': boostMultiplier,
    }, SetOptions(merge: true));

    if (countdownTimer == null || !countdownTimer!.isActive) {
      startCountdownTimer();
    }

    setState(() {});
  }

  void startCountdownTimer() {
    countdownTimer?.cancel();

    countdownTimer = Timer.periodic(const Duration(seconds: 1), (timer) {
      if (!mounted) return timer.cancel();

      if (boostEndTime == null) return;

      final remaining = boostEndTime!.difference(DateTime.now()).inSeconds;

      if (remaining <= 0) {
        timer.cancel();
        countdownTimer = null;

        setState(() {
          boostMultiplier = 1.0;
          remainingSeconds = 0;
          boostEndTime = null;
        });
      } else {
        setState(() {
          remainingSeconds = remaining;
        });
      }
    });
  }

  void activateSpeed(int speed, int secondsToAdd, {bool isRestore = false}) {
    if (!isRestore) {
      addBoostTime(secondsToAdd, speed);
      return;
    }

    countdownTimer?.cancel();
    boostMultiplier = speed.toDouble();
    startCountdownTimer();
  }

  // ================= FIREBASE =================

  Future<void> loadData() async {
    final snapshot = await userDoc.get();
    if (!snapshot.exists) return;

    final data = snapshot.data() as Map<String, dynamic>;

    setState(() {
      steps = data['steps'] ?? 0;
      coins = data['coins'] ?? 0;
      totalCoins = data['totalCoins'] ?? 0;
    });
  }

  Future<void> _restoreTimerFromFirebase() async {
    final snapshot = await userDoc.get();
    if (!snapshot.exists) return;

    final data = snapshot.data() as Map<String, dynamic>;
    Timestamp? boostTime = data['boostEndTime'];

    if (boostTime == null) return;

    DateTime endTime = boostTime.toDate();
    final remaining = endTime.difference(DateTime.now()).inSeconds;

    if (remaining > 0) {
      boostEndTime = endTime;

      activateSpeed(
        data['boostMultiplier'] ?? 3,
        remaining,
        isRestore: true,
      );
    }
  }

  Future<void> _updateFirebase() async {
    await userDoc.set({
      'steps': steps,
      'coins': coins,
      'totalCoins': totalCoins,
      'boostEndTime': boostEndTime != null
          ? Timestamp.fromDate(boostEndTime!)
          : null,
      'boostMultiplier': boostMultiplier,
    }, SetOptions(merge: true));
  }

  // ================= ADS =================

  void _loadInterstitial() {
    InterstitialAd.load(
      adUnitId: 'ca-app-pub-3940256099942544/1033173712',
      request: const AdRequest(),
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) {
          _interstitialAd = ad;
          _isInterstitialReady = true;
        },
        onAdFailedToLoad: (_) {
          _isInterstitialReady = false;
        },
      ),
    );
  }

  void _showInterstitial() {
    if (_isInterstitialReady && _interstitialAd != null) {
      _interstitialAd!.show();
      _interstitialAd = null;
      _isInterstitialReady = false;
      _loadInterstitial();
    }
  }

  // ================= NAV =================

  void showLuckySpin() {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (_) => LuckySpinScreen(
          onRewardCollected: (reward) {
            addBoostTime(60, 3);
          },
        ),
      ),
    );
  }

  // ================= UI =================

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xffB8ECFF),
      body: SafeArea(
        child: Column(
          children: [
            const SizedBox(height: 20),
            Text("Steps: $steps"),
            Text("Coins: $coins"),
            Text("Total Coins: $totalCoins"),

            if (remainingSeconds > 0)
              Column(
                children: [
                  Text("🚀 Boost x${boostMultiplier.toInt()}"),
                  Text("Time: $remainingSeconds sec"),
                ],
              ),

            const SizedBox(height: 20),

            ElevatedButton(
              onPressed: () => addBoostTime(60, 3),
              child: const Text("Watch Ad → Boost"),
            ),

            ElevatedButton(
              onPressed: showLuckySpin,
              child: const Text("Lucky Spin"),
            ),

            ElevatedButton(
              onPressed: _showInterstitial,
              child: const Text("Show Interstitial"),
            ),
          ],
        ),
      ),
    );
  }

  @override
  void dispose() {
    _stepSubscription.cancel();
    _debounce?.cancel();
    countdownTimer?.cancel();
    super.dispose();
  }
}
